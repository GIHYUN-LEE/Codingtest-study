 * 
 */


package controller;


import model.Model;
import model.domain.Person; //ctrl shift o
import view.FailView;
import view.SuccessView;


public class Controller {
	//모든 검색 메소드
	//데이터 정상 비정상 검증 : null 값으로 간단하게 진행
	public void getPersons() {
		Person data=Model.getModel().getPerson();
		
//		Model m = Model.getModel();
//		Person data = m.getPerson();
		
		if(data!=null) { //정상
			SuccessView.print("데이터가 존재합니다");
		}else {
			FailView.print("데이터가 없습니다");
		}
	}
}
