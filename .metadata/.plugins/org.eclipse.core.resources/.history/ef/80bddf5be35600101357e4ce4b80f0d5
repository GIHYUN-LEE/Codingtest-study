/* 학습
 * 1. 타입
 *    ㆍ 기본타입(8가지), 참조타입(non-premitive)
 *    ㆍ 변수에 타입을 반영
 *       - 선언 위치
 *          1. 로컬 변수
 *             - 생성자와 메소드() 또는 {} 내부에 선언
 *             - 사용시점 : 호출되었을 때만 사용되고 생성자나 메소드가 종료되면 소멸된다.
 *             - 임시변수
 *          2. 멤버 변수
 *             - class{} 내부에 선언
 *             - new와 생성자 조합으로 생성되는 객체의 데이터 실체 구성요소(사용 시점 : 객체가 존재하는 경우에만)
 *             - 멤버변수 지정 키워드 : this
 *          
 * *클래스 구성요소 : 멤버 변수, 생성자, 메소드, static{}     
 * *maven 쓰면서 target 폴더에 클래스 저장됨
 * *pom.xml에서 라이브러리 가져옴
 */

package step02;

// 사용자 정의 클래스로 참조타입의 근본 (Person 자체가 타입이 된다)
class Person{
	String name;
	int age; // ==멤버변수
	
	// age 값 수정하는 메소드
	/* 새로운 데이터 필요로 함
	 * 기능 - 새로운 데이터를 기존 데이터값 삭제하고 대체
	 * 데이터를 관리하는 변수 - age
	 * 데이터를 주고 받는 구조사이에서 메모리와 메모리를 관리하는 변수명이 필요
	 */
	void setAge(int newAge) { //newAge==로컬 변수
		String name; // 타입과 이름이면 선언이다
		age=newAge; // 또는 this.age=age;
	}
}

public class Type {
//Person에 이름값과 나이값을 메모리에 실제 사용 가능하게 실체화
	public static void main(String[] args) {
		// new Person();으로 객체를 생성 - name, age 변수공간이 실행환경 메모리에 생성됨
		Person p1 = new Person();
		System.out.println(p1); // 주소값
		p1.name="장송하"; // Person 객체 내부의 name 메모리에 저장
		System.out.println(p1.name);
		
		//age 멤버 변수에 10을 저장하고 출력해라
		p1.age=10;
		System.out.println(p1.age);
		
	}
	

}
