 *    	[body]
 *    }
 * 3. 메소드만의 주요 키워드
 *    ㆍ void - 메소드 선언부
 *    ㆍ return - 메소드 {} 내부에서 사용, 호출한 곳으로 값 주겠다는 의미
 * 4. 메소드 호출 방식
 *    ㆍ 객체 생성 후 생성된 객체를 관리하는 변수로 호출
 *    ㆍ 객체 생성없이 class명.메소드명 문법으로 호출(단, static으로 선언된 메소드만)
 *    
 * 
 */

package step02;

public class Methodlab {
// 두개의 정수 받아서 + 연산 후 출력
	static void add(int no1, int no2) {
		System.out.println(no1+no2); //
	}
	

	public static void main(String[] args) {
		Methodlab m = new Methodlab(); // 멤버변수가 없다면 객체 생성을 할 필요가 없다
		m.add(10, 20);
		
		Methodlab.add(40, 80); // static을 썼기에 가능
		add(20,30); //동일한 클래스라 가능
	}

}
